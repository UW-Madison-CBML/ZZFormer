FROM --platform=linux/amd64 tensorflow/tensorflow:2.4.0-gpu

ENV DEBIAN_FRONTEND=noninteractive
WORKDIR /app

# Fix stale NVIDIA CUDA apt key in old Ubuntu 18.04-based TF image
RUN apt-key adv --fetch-keys https://developer.download.nvidia.com/compute/cuda/repos/ubuntu1804/x86_64/3bf863cc.pub

RUN apt-get update && apt-get install -y \
    git \
    wget \
    vim \
    && rm -rf /var/lib/apt/lists/*

RUN python -m pip install --upgrade pip setuptools wheel
RUN pip install gdown

# Install your requested packages
RUN pip install \
    numpy \
    tensorflow-gpu==2.4.0 \
    matplotlib==3.1.2 \
    scikit-learn==0.21.3 \
    seaborn==0.9.0

# Optional: clone TERL
RUN git clone https://github.com/muriloHoracio/TERL.git /app/terl
WORKDIR /app/terl

# Install TERL's own GPU requirements the way the repo specifies
RUN pip install -r requirements-gpu.txt

CMD ["/bin/bash"]

